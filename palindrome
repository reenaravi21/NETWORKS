#1930 – Unique length 3 palindrome subsequences

#include <string.h>

int countPalindromicSubsequence(char* s)
{
    int ans = 0;
    int n = strlen(s);

    for (char ch = 'a'; ch <= 'z'; ch++)
    {
        int first = -1;
        int last = -1;

        for (int i = 0; i < n; i++)
        {
            if (s[i] == ch)
            {
                if (first == -1)
                    first = i;
                last = i;
            }
        }

        if (first != -1 && first < last)
        {
            int seen[26] = {0};

            for (int i = first + 1; i < last; i++)
            {
                seen[s[i] - 'a'] = 1;
            }

            for (int i = 0; i < 26; i++)
            {
                ans += seen[i];
            }
        }
    }

    return ans;
}
